<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Overlay bubble di atas game lain -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service dibutuhkan flutter_overlay_window supaya overlay
         tetap hidup walau Pulse di-minimize -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Android 11+ (API 30+): supaya device_apps bisa melihat SEMUA app
         terinstal, bukan cuma yang punya intent filter cocok. Perlu
         justifikasi khusus kalau nanti submit ke Play Store - lihat README. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Fallback non-root untuk deteksi foreground app kalau suatu saat
         root tidak tersedia (tidak dipakai di kode saat ini, disiapkan
         untuk pengembangan lanjutan) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:label="Pulse"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- WAJIB untuk flutter_overlay_window: tanpa declaration service ini,
             overlay service (foreground service tipe "specialUse") gagal start
             di Android 14+ (butuh justifikasi eksplisit per app) - dan gagalnya
             SENYAP, tidak ada crash, cuma overlay tidak pernah muncul. Ini
             kemungkinan besar penyebab "overlay FPS tidak muncul" yang kita
             alami. -->
        <service
            android:name="flutter.overlay.window.flutter_overlay_window.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="explanation_for_special_use"/>
        </service>
    </application>

    <!-- Dibutuhkan device_apps untuk resolve launch intent per package
         di Android 11+ selain QUERY_ALL_PACKAGES -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

</manifest>
